generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Notification {
  id          Int      @id @default(autoincrement())
  userId      String?
  deviceToken String
  title       String
  body        String
  data        Json?
  createdAt   DateTime @default(now())
}
